# ─── N54 Tune Program — Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# Required for protected export package encryption (AES-256-GCM)
# Minimum 32 characters recommended. Use a strong random string.
# Generate with: openssl rand -hex 32
SYNERGY_EXPORT_SECRET=change-me-before-deploying

# Admin dashboard PIN (simple PIN for v1 — replace with proper auth in production)
SYNERGY_ADMIN_PIN=change-me-before-deploying

# Optional: webhook URL for lead notifications
LEAD_WEBHOOK_URL=
